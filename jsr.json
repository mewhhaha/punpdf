{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@mewhhaha/punpdf",
  "version": "0.1.22",
  "exports": {
    ".": "./dist/index.mjs",
    "./pdfjs": "./dist/pdfjs.mjs",
    "./wasm": "./dist/wasm.mjs",
    "./wasm-module": "./dist/wasm-module.mjs"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "package.json",
      "dist/index.cjs",
      "dist/index.d.cts",
      "dist/index.d.mts",
      "dist/index.d.ts",
      "dist/index.mjs",
      "dist/pdfjs.d.mts",
      "dist/pdfjs.d.ts",
      "dist/pdfjs.mjs",
      "dist/wasm.d.mts",
      "dist/wasm.d.ts",
      "dist/wasm.mjs",
      "dist/wasm-module.d.mts",
      "dist/wasm-module.d.ts",
      "dist/wasm-module.mjs",
      "dist/punpdf_wasm.wasm",
      "dist/shared/*",
      "dist/types/**/*.d.ts"
    ]
  }
}
